            // ---------- ПЕРЕМЕННЫЕ СОСТОЯНИЯ ----------
            const audio = document.getElementById('bg-music');
            const eventDiv = document.getElementById('event-text');
            const startBtn = document.getElementById('start-btn');
            const restartBtn = document.getElementById('restart-btn');

            let timerId = null;            // id текущего таймера
            let eventsShown = 0;            // сколько событий уже показано (для нейтральных каждых 5)
            let lastTwoBonusTypes = [];      // два последних типа бонусов ('hero' или 'monster') без учёта нейтральных

            // ---------- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ----------
            function getRandomTime() {
                // от 5 до 8 минут (в миллисекундах)
                const min = 5 * 60 * 1000;  // 300000
                const max = 8 * 60 * 1000;  // 480000
                return Math.floor(Math.random() * (max - min + 1)) + min;
            }

            // Выбор случайного элемента из массива
            function randomItem(arr) {
                return arr[Math.floor(Math.random() * arr.length)];
            }

            // Основная функция выбора события с учётом правил
            function selectEvent() {
                const nextEventNumber = eventsShown + 1; // номер следующего события (1,2,3...)

                // Проверяем, должно ли событие быть нейтральным (каждое 5-е)
                if (nextEventNumber % 5 === 0) {
                    return { type: 'neutral', text: randomItem(neutralEvents) };
                }

                // Иначе выбираем между героем и монстром с учётом ограничения на 2 подряд
                let candidateType;
                const types = ['hero', 'monster'];

                // Генерируем случайный тип (0 - герой, 1 - монстр)
                const randomIndex = Math.floor(Math.random() * 2);
                candidateType = types[randomIndex];

                // Проверяем, не будет ли это третьим подряд одного типа
                if (lastTwoBonusTypes.length === 2) {
                    const [a, b] = lastTwoBonusTypes;
                    if (a === b && a === candidateType) {
                        // Будет третий подряд - меняем на противоположный
                        candidateType = (candidateType === 'hero') ? 'monster' : 'hero';
                    }
                }

                // Обновляем историю (сохраняем не больше двух)
                lastTwoBonusTypes.push(candidateType);
                if (lastTwoBonusTypes.length > 2) {
                    lastTwoBonusTypes.shift();
                }

                // Возвращаем текст в зависимости от типа
                if (candidateType === 'hero') {
                    return { type: 'hero', text: randomItem(heroBonuses) };
                } else {
                    return { type: 'monster', text: randomItem(monsterBonuses) };
                }
            }

            // Функция, вызываемая по истечении таймера
            function onTimerFinish() {
                // 1. Останавливаем музыку (ставим на паузу и сбрасываем время, чтобы при перезапуске начать с начала)
                audio.pause();
                audio.currentTime = 0;

                // 2. Меняем фон на бордовый
                document.body.style.backgroundColor = '#800000';

                // 3. Получаем событие
                const event = selectEvent();
                eventsShown++; // увеличиваем счётчик показанных событий

                // 4. Отображаем текст белым цветом
                eventDiv.style.display = 'block';
                eventDiv.style.color = 'white';
                eventDiv.textContent = event.text;

                // 5. Делаем кнопку "Перезапустить" активной
                restartBtn.disabled = false;
                startBtn.disabled = true; // старт теперь не нужен
            }

            // Запуск таймера и музыки
            function startGame() {
                if (timerId) {
                    clearTimeout(timerId);
                }

                // Сброс оформления
                document.body.style.backgroundColor = '#111';
                eventDiv.style.display = 'none';
                eventDiv.textContent = '';

                // Пытаемся играть музыку (браузер может запросить взаимодействие)
                audio.play().catch(e => {
                    console.warn('Автозапуск музыки заблокирован браузером. Нажмите "Старт" ещё раз или разрешите автозапуск.');
                    // Кнопка старта остаётся активной, пользователь нажмёт ещё раз
                });

                // Устанавливаем новый таймер на случайное время
                const delay = getRandomTime();
                console.log(`Таймер запущен на ${delay / 1000} секунд`); // для отладки (потом можно убрать)
                timerId = setTimeout(() => {
                    onTimerFinish();
                    timerId = null;
                }, delay);

                // Обновляем состояние кнопок
                startBtn.disabled = true;
                restartBtn.disabled = false;
            }

            // Перезапуск: сбрасываем всё и запускаем заново
            function restartGame() {
                // Очищаем старый таймер
                if (timerId) {
                    clearTimeout(timerId);
                    timerId = null;
                }

                // Сбрасываем счётчики и историю
                eventsShown = 0;
                lastTwoBonusTypes = [];

                // Скрываем текст и возвращаем фон
                document.body.style.backgroundColor = '#111';
                eventDiv.style.display = 'none';
                eventDiv.textContent = '';

                // Останавливаем музыку и сбрасываем её время
                audio.pause();
                audio.currentTime = 0;

                // Запускаем игру заново
                startGame();
            }

            // ---------- ПРИВЯЗКА К КНОПКАМ ----------
            startBtn.addEventListener('click', startGame);
            restartBtn.addEventListener('click', restartGame);

            // Начальное состояние: кнопка рестарта недоступна, старт доступна
            restartBtn.disabled = true;
            startBtn.disabled = false;
        })();
    </script>
</body>
</html>
